          "content": {
            "size": 6387,
            "mimeType": "text/css",
            "text": "body {\n  padding: 0;\n  margin: 0;\n  text-align: left;\n  font-family: \"Open Sans\", Arial, sans-serif;\n}\n\na,\na:hover {\n  text-decoration: none;\n}\n\n.ieducar-container {\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  min-height: 100%;\n}\n\n.ieducar-content {\n  display: flex;\n  flex: 1 1 auto !important;\n}\n\n.ieducar-sidebar {\n  width: 256px;\n  background: #e9f0f8;\n  padding-bottom: 15px;\n}\n\n.ieducar-main {\n  flex: 1 1 auto !important;\n}\n\n.ieducar-main-content {\n  padding: 0 20px;\n}\n\n.ieducar-footer {\n  width: 100%;\n  vertical-align: middle;\n  height: 34px;\n  background-color: #47728f;\n  color: #FFF;\n  font-size: 10px;\n  text-align: center;\n  line-height: 34px;\n}\n\n.ieducar-footer p {\n  margin: 0;\n}\n\n.ieducar-footer a {\n  color: #FFF;\n  text-decoration: underline;\n}\n\n.ieducar-header {\n  display: flex;\n  background: #47728f;\n  height: 50px;\n}\n\n.ieducar-header * {\n  padding: 0;\n  margin: 0;\n  list-style: none;\n}\n\n.ieducar-header-logo {\n  padding-left: 23px;\n}\n\n.ieducar-header-logo h1 a {\n  font-size: 24px;\n  font-weight: bold;\n  color: white;\n  line-height: 50px;\n}\n\n.ieducar-header-logo h1 a:hover {\n  text-decoration: none;\n}\n\n.ieducar-header-links {\n  flex: 1 1 auto;\n}\n\n.ieducar-header-links .dropbtn {\n  color: white;\n  padding: 6px 20px 6px 6px;\n  font-size: 16px;\n  border: none;\n  cursor: pointer;\n  background-image: url('../intranet/imagens/arrow-down.png');\n  background-repeat: no-repeat;\n  background-position: center right;\n  background-size: 12px;\n}\n\n.ieducar-header-links .dropbtn:hover,\n.dropdown:hover .dropbtn {\n  background-image: url('../intranet/imagens/arrow-up.png');\n  background-repeat: no-repeat;\n  background-position: center right;\n}\n\n.ieducar-header-links .dropdown {\n  position: relative;\n  display: inline-block;\n}\n\n.ieducar-header-links .dropdown-content {\n  display: none;\n  position: absolute;\n  background-color: #f9f9f9;\n  min-width: 150px;\n  box-shadow: 0 8px 16px 0 rgba(0, 0, 0, 0.2);\n  z-index: 1;\n  right: 0;\n}\n\n.ieducar-header-links .dropdown-content a {\n  color: #646b71;\n  padding: 12px 16px;\n  text-decoration: none;\n  display: block;\n  text-align: left;\n  font-size: 14px;\n}\n\n.ieducar-header-links .dropdown-content a:hover {\n  color: #188ad1\n}\n\n.ieducar-header-links .dropdown:hover .dropdown-content {\n  display: block;\n}\n\n.ieducar-header-links .dropdown {\n  float: right;\n  margin: 7px 23px 0 0;\n}\n\n.notifications {\n  float: right;\n  margin: 7px 0 0;\n}\n\n.notifications img {\n  position: relative;\n  top: 7px;\n  width: 20px;\n}\n\n.avatar {\n  float: right;\n  margin: 7px 10px 0 0;\n}\n\n.ieducar-quick-search {\n  padding: 0 23px;\n}\n\n.ieducar-quick-search label {\n  display: block;\n  width: 100%;\n}\n\n.ieducar-quick-search-input {\n  border: solid 1px #cddce6;\n  color: #47728f;\n  border-radius: 3px;\n  background-color: white;\n  font-size: 12px;\n  padding: 11px;\n  margin: 0 0 10px;\n  width: 100%;\n  box-sizing: border-box;\n}\n\n.ieducar-quick-search-title {\n  color: #47728f;\n  font-size: 12px;\n  text-transform: uppercase;\n  font-weight: bold;\n}\n\n.ieducar-sidebar-menu {\n  width: 256px;\n  padding: 0;\n  margin: 0;\n}\n\n.ieducar-sidebar-menu li {\n  padding: 0;\n  margin: 0;\n  list-style: none;\n}\n\n.ieducar-sidebar-menu li a {\n  display: block;\n  color: #47728f;\n  font-family: \"Open Sans\", sans-serif;\n  font-size: 16px;\n  padding: 17px 15px;\n  margin: 0 10px;\n  -webkit-border-radius: 3px;\n  -moz-border-radius: 3px;\n  border-radius: 3px;\n}\n\n.ieducar-sidebar-menu li a:hover {\n  background: #cddce6;\n  text-decoration: none;\n}\n\n.ieducar-sidebar-menu-active {\n  background: #cddce6;\n  text-decoration: none;\n}\n\n.ieducar-sidebar-menu li a i {\n  color: #98b0c3;\n  font-size: 20px;\n  padding-right: 10px;\n  width: 32px;\n  text-align: center;\n}\n\n.ui-menu-item {\n  font-size: 11px;\n}\n\n.ieducar-menu,\n.ieducar-sub-menu {\n  margin: 0;\n  padding: 0;\n}\n\n.clearfix:after {\n  content: '.';\n  display: block;\n  clear: both;\n  height: 0;\n  line-height: 0;\n  font-size: 0;\n  visibility: hidden;\n  overflow: hidden;\n}\n\n.ieducar-menu,\n.ieducar-sub-menu {\n  list-style: none;\n  background: #e9eff7;\n}\n\n.ieducar-sub-menu {\n  background: #FFF;\n  border: 1px solid #f3f3f3;\n}\n\n.ieducar-menu a {\n  text-decoration: none;\n  display: block;\n  padding: 10px;\n  color: #47728f;\n  font-family: \"Open Sans\", sans-serif;\n  font-size: 16px;\n}\n\n.ieducar-menu a:hover {\n  text-decoration: none;\n}\n\n.ieducar-menu li {\n  position: relative;\n}\n\n.ieducar-menu > li {\n  float: left;\n}\n\n.ieducar-menu > li:hover {\n  background: #cddce6;\n}\n\n.ieducar-menu li:hover > .ieducar-sub-menu {\n  display: block;\n}\n\n.ieducar-sub-menu a {\n  font-size: 14px;\n}\n\n.ieducar-sub-menu {\n  display: none;\n  position: absolute;\n  min-width: 220px;\n  z-index: 1100;\n}\n\n.ieducar-sub-menu li a {\n  color: #646b71;\n  padding: 5px 10px;\n}\n\n.ieducar-sub-menu li + li {\n  border-top: 1px solid #f3f3f3;\n}\n\n.ieducar-sub-menu li:hover {\n  background: #cddce6;\n}\n\n.ieducar-sub-menu .ieducar-sub-menu {\n  top: -1px;\n  left: 100%;\n}\n\n/** Legacy **/\n#corpo a:hover {\n  text-decoration: underline;\n}\n\n.breadcrumb {\n  margin: 15px 0 0;\n}\n\n.breadcrumb a,\n.breadcrumb span {\n  font-weight: bold !important;\n  color: #47728f;\n  font-size: 14px !important;\n}\n\n.breadcrumb .breadcrumb-current,\n.breadcrumb .breadcrumb-current:hover,\n.breadcrumb .breadcrumb-separator,\n.breadcrumb .breadcrumb-separator:hover {\n  color: #999 !important;\n}\n\n.beta-badge {\n  position: absolute;\n  margin-left: 10px;\n}\n\n.quick-search {\n  margin-bottom: 10px;\n}\n\n.quick-search .multiselect,\n.quick-search .multiselect__input,\n.quick-search .multiselect__single {\n  font-size: 12px;\n}\n\n.quick-search input[type=\"text\"].multiselect__input {\n  padding: 0 5px !important;\n  border: none !important;\n}\n\n.quick-search .multiselect__tags {\n  padding: 10px 8px 0 8px;\n  border: 1px solid #cddce6;\n  border-radius: 3px;\n  color: #777;\n}\n\n.quick-search .multiselect__content-wrapper {\n  border: 1px solid #cddce6;\n  border-bottom-left-radius: 3px;\n  border-bottom-right-radius: 3px;\n  min-width: 100%;\n  width: auto;\n  margin-top: -1px;\n}\n\n.quick-search .multiselect__option--highlight {\n  background: #cddce6;\n}\n\n.quick-search a {\n  color: #47728f;\n}\n\n.quick-search a:hover {\n  text-decoration: none;\n}\n\n.vue-template {\n  display: none;\n}\n\n.avatar-35 {\n  width: 35px;\n  height: 35px;\n  border-radius: 50%;\n  object-fit: cover;\n  vertical-align: middle;\n}\n\n.ml-5 {\n  margin-left: 5px;\n}\n\n.text-center {\n  text-align: center;\n}\n"
