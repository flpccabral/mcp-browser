            "mimeType": "text/css",
            "text": ".flashMessages {\n  font-size: 14px;\n  left: 0;\n  margin: 0 auto;\n  max-height: 100vh;\n  overflow-y: auto;\n  position: fixed;\n  right: 0;\n  top: 0;\n  z-index: 90000;\n}\n\n.flashMessages * {\n  pointer-events: auto;\n}\n\n.flashMessages__controls {\n  margin: 0;\n  padding: 0 12px 0 0;\n  pointer-events: none;\n  text-align: right;\n}\n\n.flashMessages__controls li {\n  display: inline-block;\n  margin: 12px 12px 12px 0;\n}\n\n.flashMessages__controls li a {\n  background-color: rgba(0, 0, 0, .75);\n  border-radius: 13px;\n  color: white;\n  display: inline-block;\n  font-size: 10px;\n  font-weight: bold;\n  padding: 6px 12px;\n  text-decoration: none;\n  text-transform: uppercase;\n}\n\n.flashMessages__message {\n  background-color: lightgray;\n  border-radius: 8px;\n  box-shadow: 0 0 10px rgba(0, 0, 0, .5);\n  color: rgba(0, 0, 0, .75);\n  margin: 24px 24px;\n  padding: 15px;\n  position: relative;\n}\n\n.flashMessages__message:last-child {\n  margin-bottom: 12px;\n}\n\n.flashMessages__message.-success {\n  color: #157100;\n  background-color: #F0F9EE;\n}\n\n.flashMessages__message.-error {\n  color: #FF4E4E;\n  background-color: #FFEEEE;\n}\n\n.flashMessages__message.-info {\n  color: #3A87AD;\n  background-color: #BCE8F1;\n}\n\n.flashMessages__message.-legacy {\n  color: #3A87AD;\n  background-color: #BCE8F1;\n}\n\n.flashMessages__message.-notice {\n  color: #67664f;\n  background-color: #fffee0;\n}\n\n.flashMessages__message .close-msg {\n  color: #999;\n  display: block;\n  font-size: 16px;\n  font-weight: bold;\n  position: absolute;\n  right: 15px;\n  text-decoration: none;\n  top: 10px;\n}\n\n.flashMessages__message time {\n  display: block;\n  font-size: 10px;\n  font-weight: bold;\n  margin-bottom: 4px;\n}\n\n.msg-diario.flashMessages {\n  width: 400px;\n  left: auto;\n}\n"
