# Copie para .env e ajuste. O servidor carrega o .env automaticamente
# (via python-dotenv em src/browser_mcp/__init__.py).

# ── LLM (agente autônomo) ─────────────────────────────────────────────
# Provedor: deepseek | openai | anthropic | ollama (outros caem no fallback OpenAI-compatible)
LLM_PROVIDER=deepseek

# Chave de API do provedor escolhido (obrigatória para provedores pagos)
LLM_API_KEY=

# (Opcional) Modelo do chat. Default por provedor:
#   deepseek → deepseek-chat | openai → gpt-4o-mini
#   anthropic → claude-sonnet-4-20250514 | ollama → llama3.1
# LLM_MODEL=

# (Opcional) Endpoint OpenAI-compatible. Default por provedor
# (ex.: https://api.deepseek.com/v1). Use para proxies/gateways/self-hosted.
# LLM_BASE_URL=

# ── Browser (Playwright) ──────────────────────────────────────────────
# Rodar sem interface gráfica (true|false)
BROWSER_HEADLESS=true

# Viewport inicial (px)
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720

# Timeout padrão de operações do navegador (ms)
BROWSER_TIMEOUT=30000

# Ativar ajustes anti-detecção + user-agent realista (true|false)
STEALTH_MODE=true

# Injetar overlay visual após navegação Playwright (true|false)
ENABLE_VISUAL_INDICATOR=true

# (Opcional) Diretório de destino de browser_download
# BROWSER_MCP_DOWNLOAD_DIR=

# ── Modo extensão (bridge WebSocket) ──────────────────────────────────
# URL do bridge WebSocket usada por browser_connect_to_extension
EXTENSION_WS_URL=ws://localhost:8765
